---
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';
import AuthorCard from '../components/AuthorCard.astro';
import TableOfContents from '../components/TableOfContents.astro';
import authors from '../data/authors';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    author: string;
    tags?: string[];
  };
  headings: { depth: number; slug: string; text: string }[];
}

const { frontmatter, headings } = Astro.props;

const author = authors[frontmatter.author];
if (!author) {
  throw new Error(`Unknown author "${frontmatter.author}". Add them to src/data/authors.ts.`);
}

const formattedDate = frontmatter.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="post-article">
    <TableOfContents headings={headings} />
    <header class="post-header">
      <h1>{frontmatter.title}</h1>
      <div class="post-meta">
        <time datetime={frontmatter.pubDate.toISOString()}>{formattedDate}</time>
        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <ul class="tags">
            {frontmatter.tags.map(tag => <li>{tag}</li>)}
          </ul>
        )}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>

    <AuthorCard name={author.name} profile={author.profile} bio={author.bio} />

    <Giscus
      repo="patr-cloud/blog"
      repoId="R_kgDORrQjyQ"
      category="Blog Comments"
      categoryId="DIC_kwDORrQjyc4C4ysj"
    />
  </article>
</BaseLayout>

<style>
  .post-article { position: relative; }
  .post-header { margin-bottom: 2rem; }
  .post-header h1 { font-size: 2rem; line-height: 1.2; margin: 0 0 0.75rem; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tags li {
    background: #2e2450;
    border: 1px solid #f89b4133;
    border-radius: 3px;
    padding: 0.1rem 0.5rem;
    font-size: 0.8rem;
    color: #f89b41;
  }
</style>
